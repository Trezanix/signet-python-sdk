# =====================================================================
# 🛡️ SIGNET SDK - ENVIRONMENT CONFIGURATION TEMPLATE
# =====================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to exactly `.env`
# 2. Replace the placeholder values below with your actual credentials
#    from the Signet Dashboard.
# 3. NEVER commit the real `.env` file to your version control (Git).
# =====================================================================

# 1. Your Signet Console API URL (e.g., https://signet.trezanix.com)
SIGNET_API_URL="http://127.0.0.1:8000"

# 2. Your Application's API Key (Generated in the 'api_keys' table)
SIGNET_API_KEY="sgnt_live_YOUR_API_KEY_HERE"

# 3. The exact product slug configured in your database for this specific app
SIGNET_PRODUCT_SLUG="your-product-slug-here"

# 4. Your ECDSA Public Key from the Dashboard
# IMPORTANT: Ensure the format retains the PEM Header & Footer. 
# Write it in a single line using \n for line breaks as shown below.
SIGNET_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_FIRST_LINE_DATA_HERE\nYOUR_PUBLIC_KEY_SECOND_LINE_DATA_HERE\n-----END PUBLIC KEY-----"